# Cle API Mistral (https://console.mistral.ai/) — jamais dans le depot.
MISTRAL_API_KEY=

# Identifiants OAuth Google (https://console.cloud.google.com/, API
# "YouTube Data API v3" activee, client "Application web" avec redirection
# http://127.0.0.1 autorisee) — jamais dans le depot.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Optionnel : refresh token YouTube. A defaut, `cli youtube-auth` le stocke
# dans data/youtube_token.json (gitignore).
YOUTUBE_REFRESH_TOKEN=
